# ======================
# GravityClaw Configuration
# ======================

# --- LLM Providers (pelo menos um é obrigatório) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...         # Para Gemini (opcional)
# LOCAL_LLM_URL=http://localhost:11434  # Para Ollama ou similar

# Modelo padrão: anthropic, openai, google, local
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514

# --- Gateway ---
# PORT é definido automaticamente pelo Railway para a porta HTTP pública.
GATEWAY_PORT=3100
WEBHOOK_PORT=3101
DASHBOARD_PORT=3000
GATEWAY_TOKEN=change-me-to-a-strong-secret

# --- Canais (configure conforme necessário) ---
TELEGRAM_BOT_TOKEN=...
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
# DISCORD_BOT_TOKEN=...
# WHATSAPP_PHONE_NUMBER_ID=...
# WHATSAPP_ACCESS_TOKEN=...

# --- Memória ---
MEMORY_DIR=./data/memory

# --- Integrações (MCP) ---
# MCP_SQLITE_PATH=/Users/ana/Documents/meu_banco.db
# GITHUB_PERSONAL_ACCESS_TOKEN=classic_token_here
# NOTION_API_KEY=secret_notion_key
# GOOGLE_DRIVE_MCP_AUTH_TOKEN=drive_token
# MCP_POSTGRES_URL=postgresql://user:password@localhost:5432/mydb

# --- Specialists / Providers ---
OPENROUTER_API_KEY=sk-or-...
ASSEMBLYAI_API_KEY=...
LEONARDO_API_KEY=...
BRAVE_SEARCH_API_KEY=...

# --- Google Drive OAuth (JSON serializado) ---
GOOGLE_DRIVE_ROOT_FOLDER_ID=...
# GOOGLE_OAUTH_CREDENTIALS={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["..."]}}
# GOOGLE_TOKEN={"access_token":"...","refresh_token":"...","scope":"https://www.googleapis.com/auth/drive","token_type":"Bearer","expiry_date":1234567890}
